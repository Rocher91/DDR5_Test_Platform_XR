/* =========================================================
 * GPIO clock enable helper
 * ========================================================= */
static inline void BOARD_GPIO_ClocksEnable(void)
{
    LL_AHB2_GRP1_EnableClock(LL_AHB2_GRP1_PERIPH_GPIOB);
    LL_AHB2_GRP1_EnableClock(LL_AHB2_GRP1_PERIPH_GPIOC);
    LL_AHB2_GRP1_EnableClock(LL_AHB2_GRP1_PERIPH_GPIOD);
    LL_AHB2_GRP1_EnableClock(LL_AHB2_GRP1_PERIPH_GPIOE);
    LL_AHB2_GRP1_EnableClock(LL_AHB2_GRP1_PERIPH_GPIOF);
}

/* =========================================================
 * Small read/write helpers
 * ========================================================= */
static inline uint32_t BOARD_ReadPin(GPIO_TypeDef *port, uint32_t pin)
{
    return (LL_GPIO_IsInputPinSet(port, pin) != 0U) ? PIN_HIGH : PIN_LOW;
}

static inline void BOARD_WritePin(GPIO_TypeDef *port, uint32_t pin, uint32_t value)
{
    if (value == PIN_HIGH) {
        LL_GPIO_SetOutputPin(port, pin);
    } else {
        LL_GPIO_ResetOutputPin(port, pin);
    }
}

static inline uint32_t BOARD_ButtonIsPressed(GPIO_TypeDef *port, uint32_t pin)
{
    return (BOARD_ReadPin(port, pin) == BTN_PRESSED_LEVEL) ? 1U : 0U;
}

